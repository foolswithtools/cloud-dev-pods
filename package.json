{
  "name": "cloud-dev-pods",
  "version": "0.1.0",
  "private": true,
  "description": "Provision ECS-based VS Code dev pods in your own AWS account.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/foolswithtools/cloud-dev-pods",
  "repository": {
    "type": "git",
    "url": "https://github.com/foolswithtools/cloud-dev-pods.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "infra",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -b infra scripts",
    "lint": "eslint .",
    "test": "vitest run",
    "synth": "npm --workspace infra run synth",
    "init": "tsx scripts/init-clone.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
