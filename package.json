{
  "name": "cloud-dev-pods",
  "version": "0.1.0",
  "private": true,
  "description": "Provision ECS-based VS Code dev pods in your own AWS account.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/foolswithtools/cloud-dev-pods",
  "repository": {
    "type": "git",
    "url": "https://github.com/foolswithtools/cloud-dev-pods.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "infra",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -b infra scripts",
    "lint": "eslint .",
    "test": "vitest run",
    "synth": "npm --workspace infra run synth",
    "init": "tsx scripts/init-clone.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.24.0",
    "eslint": "^10.3.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "fast-xml-builder": "^1.2.0"
  }
}
